---
import SandboxLayout from "../../layouts/SandboxLayout.astro";
import ResultsPanel from "../../components/sandbox/ResultsPanel.astro";
import QuantumCanvas from "../../components/sandbox/QuantumCanvas.astro";
import QuantumTones from "../../components/sandbox/QuantumTones.astro";
---

<SandboxLayout
  title="Quantum Sandbox"
  subtitle="Drag gates, sweep rotations, share what you build via URL — no backend, no signup."
  description="Open-ended quantum circuit composer with live state visualization, challenge puzzles, and creative outputs."
>
  <div
    id="sandbox-root"
    class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-4"
  >
    <section aria-label="Composer" class="space-y-4">
      <div
        data-sandbox-toolbar
        class="flex flex-wrap items-center gap-2 rounded-lg border border-line bg-surface-elevated/40 px-3 py-2 text-sm"
        role="toolbar"
        aria-label="Sandbox actions"
      >
        <button
          type="button"
          data-action="undo"
          class="rounded bg-surface-sunken hover:bg-line-strong disabled:opacity-40 disabled:cursor-not-allowed px-3 py-1 text-ink"
          title="Undo (⌘Z)"
        >Undo</button>
        <button
          type="button"
          data-action="redo"
          class="rounded bg-surface-sunken hover:bg-line-strong disabled:opacity-40 disabled:cursor-not-allowed px-3 py-1 text-ink"
          title="Redo (⌘⇧Z)"
        >Redo</button>
        <button
          type="button"
          data-action="share"
          class="rounded bg-positive hover:bg-positive px-3 py-1 text-white"
          title="Copy share URL"
        >Copy share URL</button>
        <button
          type="button"
          data-action="save-gallery"
          class="rounded bg-accent hover:bg-accent-emphasis px-3 py-1 text-white"
          title="Save to local gallery"
        >Save</button>
        <a
          href="/gallery"
          class="rounded bg-surface-sunken hover:bg-line-strong px-3 py-1 text-ink-muted hover:text-ink"
          title="Open the gallery"
        >Gallery →</a>
        <button
          type="button"
          data-action="reset"
          class="rounded bg-surface-sunken hover:bg-line-strong px-3 py-1 text-ink-muted"
          title="Reset to empty circuit"
        >Reset</button>
        <label class="ml-auto flex items-center gap-2 text-ink-subtle">
          Qubits:
          <select
            data-action="qubits"
            class="rounded bg-surface-sunken border border-line-strong px-2 py-1 text-ink"
            aria-label="Number of qubits"
          >
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
        </label>
      </div>
      <div
        data-sandbox-grid
        class="relative overflow-x-auto rounded-lg border border-line bg-surface-elevated/40 p-3 grid gap-1.5 min-w-fit"
      >
        <!-- composer.client.ts hydrates this -->
      </div>
      <ResultsPanel />
      <QuantumCanvas />
      <QuantumTones />
    </section>

    <aside aria-label="Tools" class="space-y-4">
      <div
        data-sandbox-palette
        class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-3 gap-2 p-3 rounded-lg border border-line bg-surface-elevated/60"
      >
        <!-- composer.client.ts hydrates this -->
      </div>
      <div class="rounded-lg border border-line bg-surface-elevated/40 p-3 text-xs text-ink-subtle space-y-2">
        <p class="text-ink font-medium">How to play</p>
        <ul class="list-disc list-inside space-y-1">
          <li>Click a gate to arm it, then click a grid cell to drop. Or use shortcut keys (shown on each button) to insert at the selected cell.</li>
          <li>For CNOT: drop on the <em>control</em> qubit, then tap the target in the same column.</li>
          <li>Click an Rx/Ry/Rz cell to open the θ slider. Arrow keys nudge θ.</li>
          <li>Right-click any cell (or <kbd class="font-mono">Backspace</kbd> at the selection) to remove its op.</li>
          <li>Arrow keys move the selection. <kbd class="font-mono">Esc</kbd> cancels pickup or closes the popover.</li>
        </ul>
      </div>
    </aside>
  </div>

  {/* Save-to-gallery dialog — native <dialog> for free modal a11y. */}
  <dialog
    data-role="save-dialog"
    class="rounded-lg border border-line-strong bg-surface-elevated p-6 text-ink backdrop:bg-surface/80 backdrop:backdrop-blur-sm w-[min(90vw,28rem)]"
  >
    <form data-role="save-form" method="dialog" class="space-y-4">
      <h2 class="text-lg font-semibold text-ink">Save circuit to gallery</h2>
      <p class="text-sm text-ink-muted">
        Stored locally in this browser. Browse, rename, or export at any time from the
        <a href="/gallery" class="text-accent hover:text-accent-emphasis underline">gallery</a>.
      </p>
      <label class="block">
        <span class="block text-sm font-medium text-ink mb-1">Name</span>
        <input
          data-role="save-name"
          type="text"
          required
          maxlength="80"
          class="w-full rounded-md border border-line bg-surface px-3 py-2 text-ink focus:outline-none focus:ring-2 focus:ring-accent"
        />
      </label>
      <div class="flex items-center justify-end gap-3 pt-2">
        <button
          type="button"
          data-role="save-cancel"
          class="text-sm text-ink-subtle hover:text-ink px-3 py-2"
        >Cancel</button>
        <button
          type="submit"
          class="rounded-md bg-accent px-4 py-2 text-sm font-semibold text-white hover:bg-accent-emphasis focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-surface-elevated"
        >Save</button>
      </div>
    </form>
  </dialog>
</SandboxLayout>

<script>
  import { mountComposer } from "../../lib/sandbox/composer.client";
  import { mountToast } from "../../lib/sandbox/toast.client";
  import { mountResults } from "../../lib/sandbox/results.client";

  const init = () => {
    const root = document.getElementById("sandbox-root");
    if (!root) return;
    mountComposer(root as HTMLElement);
    mountToast();
    mountResults(root as HTMLElement);

    // Save-to-gallery is lazy — only pulled in when the user hovers
    // or focuses the Save button. Keeps idb-keyval out of the
    // critical sandbox bundle until needed.
    const saveBtn = document.querySelector<HTMLButtonElement>('[data-action="save-gallery"]');
    if (saveBtn) {
      let loaded = false;
      const load = () => {
        if (loaded) return;
        loaded = true;
        import("../../lib/sandbox/gallery-save.client").then(({ mountSaveToGallery }) => {
          mountSaveToGallery(document.body);
          // Click the button again to actually open the dialog if the
          // user pressed Save (rather than just hovered).
        }).catch((err) => console.warn("[gallery-save] load failed", err));
      };
      saveBtn.addEventListener("pointerenter", load, { once: true });
      saveBtn.addEventListener("focus", load, { once: true });
      saveBtn.addEventListener("click", load, { once: true });
    }

    // Both creative widgets are lazy-mounted via IntersectionObserver
    // so the composer up top stays the fast critical path. Each pays
    // for its own JS chunk only when it scrolls into view.
    lazyMount(
      root.querySelector<HTMLElement>("[data-quantum-canvas-root]"),
      () => import("../../lib/sandbox/canvas.client").then(
        ({ mountCanvas }) => mountCanvas,
      ),
      "QuantumCanvas",
    );
    lazyMount(
      root.querySelector<HTMLElement>("[data-quantum-tones-root]"),
      () => import("../../lib/sandbox/tones.client").then(
        ({ mountTones }) => mountTones,
      ),
      "QuantumTones",
    );
  };

  function lazyMount(
    target: HTMLElement | null,
    loader: () => Promise<(el: HTMLElement) => void>,
    label: string,
  ): void {
    if (!target) return;
    const hydrate = () => loader()
      .then((mount) => mount(target))
      .catch((err) => console.warn(`[${label}] mount failed`, err));

    if (typeof IntersectionObserver === "function") {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            io.disconnect();
            hydrate();
            return;
          }
        }
      }, { rootMargin: "200px" });
      io.observe(target);
    } else {
      hydrate();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
