---
import SandboxLayout from "../../layouts/SandboxLayout.astro";
import ResultsPanel from "../../components/sandbox/ResultsPanel.astro";
import QuantumCanvas from "../../components/sandbox/QuantumCanvas.astro";
---

<SandboxLayout
  title="Quantum Sandbox"
  subtitle="Drag gates, sweep rotations, share what you build via URL — no backend, no signup."
  description="Open-ended quantum circuit composer with live state visualization, challenge puzzles, and creative outputs."
>
  <div
    id="sandbox-root"
    class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-4"
  >
    <section aria-label="Composer" class="space-y-4">
      <div
        data-sandbox-toolbar
        class="flex flex-wrap items-center gap-2 rounded-lg border border-slate-800 bg-slate-900/40 px-3 py-2 text-sm"
        role="toolbar"
        aria-label="Sandbox actions"
      >
        <button
          type="button"
          data-action="undo"
          class="rounded bg-slate-800 hover:bg-slate-700 disabled:opacity-40 disabled:cursor-not-allowed px-3 py-1 text-slate-200"
          title="Undo (⌘Z)"
        >Undo</button>
        <button
          type="button"
          data-action="redo"
          class="rounded bg-slate-800 hover:bg-slate-700 disabled:opacity-40 disabled:cursor-not-allowed px-3 py-1 text-slate-200"
          title="Redo (⌘⇧Z)"
        >Redo</button>
        <button
          type="button"
          data-action="share"
          class="rounded bg-emerald-600 hover:bg-emerald-500 px-3 py-1 text-white"
          title="Copy share URL"
        >Copy share URL</button>
        <button
          type="button"
          data-action="reset"
          class="rounded bg-slate-800 hover:bg-slate-700 px-3 py-1 text-slate-300"
          title="Reset to empty circuit"
        >Reset</button>
        <label class="ml-auto flex items-center gap-2 text-slate-400">
          Qubits:
          <select
            data-action="qubits"
            class="rounded bg-slate-800 border border-slate-700 px-2 py-1 text-slate-200"
            aria-label="Number of qubits"
          >
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
        </label>
      </div>
      <div
        data-sandbox-grid
        class="relative overflow-x-auto rounded-lg border border-slate-800 bg-slate-900/40 p-3 grid gap-1.5 min-w-fit"
      >
        <!-- composer.client.ts hydrates this -->
      </div>
      <ResultsPanel />
      <QuantumCanvas />
    </section>

    <aside aria-label="Tools" class="space-y-4">
      <div
        data-sandbox-palette
        class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-3 gap-2 p-3 rounded-lg border border-slate-800 bg-slate-900/60"
      >
        <!-- composer.client.ts hydrates this -->
      </div>
      <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-3 text-xs text-slate-400 space-y-2">
        <p class="text-slate-200 font-medium">How to play</p>
        <ul class="list-disc list-inside space-y-1">
          <li>Click a gate to arm it, then click a grid cell to drop. Or use shortcut keys (shown on each button) to insert at the selected cell.</li>
          <li>For CNOT: drop on the <em>control</em> qubit, then tap the target in the same column.</li>
          <li>Click an Rx/Ry/Rz cell to open the θ slider. Arrow keys nudge θ.</li>
          <li>Right-click any cell (or <kbd class="font-mono">Backspace</kbd> at the selection) to remove its op.</li>
          <li>Arrow keys move the selection. <kbd class="font-mono">Esc</kbd> cancels pickup or closes the popover.</li>
        </ul>
      </div>
    </aside>
  </div>
</SandboxLayout>

<script>
  import { mountComposer } from "../../lib/sandbox/composer.client";
  import { mountToast } from "../../lib/sandbox/toast.client";
  import { mountResults } from "../../lib/sandbox/results.client";

  const init = () => {
    const root = document.getElementById("sandbox-root");
    if (!root) return;
    mountComposer(root as HTMLElement);
    mountToast();
    mountResults(root as HTMLElement);

    // Quantum Canvas pays for its Web Worker chunk only when it scrolls
    // into view — the composer up top stays the fast critical path.
    const canvasRoot = root.querySelector<HTMLElement>("[data-quantum-canvas-root]");
    if (canvasRoot) {
      const hydrate = () => import("../../lib/sandbox/canvas.client")
        .then(({ mountCanvas }) => mountCanvas(canvasRoot))
        .catch((err) => console.warn("[QuantumCanvas] mount failed", err));

      if (typeof IntersectionObserver === "function") {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              io.disconnect();
              hydrate();
              return;
            }
          }
        }, { rootMargin: "200px" });
        io.observe(canvasRoot);
      } else {
        hydrate();
      }
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
