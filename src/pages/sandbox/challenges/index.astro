---
/**
 * `/sandbox/challenges` — list page.
 *
 * Per the Phase 3 context decision, all five puzzles are open from
 * the start (browsing > forced linearity for a creative-first site).
 * Each card carries the title, a qubits badge, the brief, and a
 * "Start" link to the per-puzzle page.
 */
import SandboxLayout from "../../../layouts/SandboxLayout.astro";
import { PUZZLES } from "../../../lib/sandbox/challenges/data";
---

<SandboxLayout
  title="Challenges"
  subtitle="Five hand-picked puzzles to turn the sandbox into a guided tour. Pick any one — they're all open from the start."
  description="Quantum sandbox challenges: build named states (|+⟩, Bell, GHZ, ...) and get instant fidelity feedback."
>
  <section
    aria-label="Puzzle list"
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
  >
    {PUZZLES.map((p, idx) => (
      <a
        href={`/sandbox/challenges/${p.slug}`}
        class="group flex flex-col gap-3 rounded-lg border border-slate-800 bg-slate-900/40 p-5 hover:border-indigo-500/70 hover:bg-slate-900/70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-300 transition-colors"
      >
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs uppercase tracking-widest text-slate-500">
            #{String(idx + 1).padStart(2, "0")}
          </span>
          <span class="rounded-full border border-slate-700 bg-slate-800 px-2 py-0.5 text-xs font-mono text-slate-300">
            {p.qubits} qubit{p.qubits === 1 ? "" : "s"}
          </span>
        </div>
        <h2 class="text-lg font-semibold text-slate-100 group-hover:text-white">
          {p.title}
        </h2>
        <p class="text-sm text-slate-400 leading-relaxed flex-1">
          {p.brief}
        </p>
        <span class="text-sm font-medium text-indigo-400 group-hover:text-indigo-300">
          Start →
        </span>
      </a>
    ))}
  </section>

  <p class="mt-8 text-sm text-slate-500 max-w-2xl">
    Each puzzle watches the circuit you build and reports a state
    fidelity F ∈ [0, 1] against a target state. F ≥ 0.99 counts as
    solved; anything in [0.90, 0.99) is "close" and worth tuning.
    Stuck? Each card has progressive hints.
  </p>
</SandboxLayout>
