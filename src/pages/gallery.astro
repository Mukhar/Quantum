---
/**
 * /gallery — local circuit gallery.
 *
 * IndexedDB-backed grid of saved circuits. CRUD inline on each card.
 * Export/import in the header. Click a card → opens in /sandbox via
 * the URL-fragment codec (no parallel hydration path).
 *
 * Page bundle is loaded only here (and the sandbox save drawer);
 * essay routes do not pull gallery code.
 */
import EssayLayout from "../layouts/EssayLayout.astro";
---

<EssayLayout
  title="Gallery"
  subtitle="Your saved circuits — locally stored, exportable."
  pageTitle="Gallery — Quantum"
  description="Browse, rename, duplicate, export, and re-open your saved quantum circuits."
  ogType="website"
>
  <p class="text-ink-muted">
    Everything here lives in your browser's IndexedDB. Nothing is sent
    to a server. Export the whole shelf as JSON anytime — back up,
    move to another machine, or share a single circuit.
  </p>

  <div
    data-role="fallback-banner"
    role="status"
    class="hidden my-6 rounded-md border border-warning/40 bg-warning/10 px-4 py-3 text-sm text-warning"
  >
    <strong>Private browsing detected.</strong> IndexedDB is blocked,
    so saves stay in memory until you close this tab. Export to JSON
    if you want to keep them.
  </div>

  <div
    data-role="quota-banner"
    role="status"
    class="hidden my-6 rounded-md border border-warning/40 bg-warning/10 px-4 py-3 text-sm text-warning"
  >
    <strong>Heads up:</strong> you have more than 100 saved circuits.
    Browser storage quota is generous (≥ 50 MB usually) but consider
    exporting + clearing if you notice slowness.
  </div>

  <div class="not-prose mt-8 flex flex-wrap items-center gap-3">
    <button
      data-role="export-btn"
      type="button"
      class="rounded-md border border-line-strong bg-surface-elevated px-3 py-1.5 text-sm text-ink hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent"
    >
      Export all
    </button>
    <label class="rounded-md border border-line-strong bg-surface-elevated px-3 py-1.5 text-sm text-ink hover:border-accent focus-within:ring-2 focus-within:ring-accent cursor-pointer">
      Import JSON
      <input
        data-role="import-input"
        type="file"
        accept="application/json,.json"
        class="sr-only"
      />
    </label>
    <button
      data-role="clear-btn"
      type="button"
      class="rounded-md border border-warning/40 bg-warning/10 px-3 py-1.5 text-sm text-warning hover:bg-warning/20 focus:outline-none focus:ring-2 focus:ring-warning"
    >
      Clear all
    </button>
    <span data-role="status-msg" class="text-sm text-ink-subtle" role="status" aria-live="polite"></span>
  </div>

  <div
    data-role="empty-state"
    class="hidden mt-12 rounded-lg border border-dashed border-line p-12 text-center"
  >
    <p class="text-ink">No circuits saved yet.</p>
    <p class="mt-2 text-sm text-ink-subtle">
      Head to <a href="/sandbox" class="text-accent hover:text-accent-emphasis underline">the sandbox</a>,
      build something, and click <em>Save</em>.
    </p>
  </div>

  <ul
    data-role="grid"
    class="not-prose mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
  ></ul>

  <script>
    import { loadAll, deleteOne, renameOne, duplicate, exportAll, importMany, clear, usingFallback, subscribe } from "../lib/gallery/store";
    import { encodeCircuit } from "../lib/quantum/codec";
    import type { GalleryEntry } from "../lib/gallery/schema";

    const grid = document.querySelector<HTMLElement>('[data-role="grid"]');
    const empty = document.querySelector<HTMLElement>('[data-role="empty-state"]');
    const fallbackBanner = document.querySelector<HTMLElement>('[data-role="fallback-banner"]');
    const quotaBanner = document.querySelector<HTMLElement>('[data-role="quota-banner"]');
    const statusMsg = document.querySelector<HTMLElement>('[data-role="status-msg"]');

    function setStatus(msg: string): void {
      if (!statusMsg) return;
      statusMsg.textContent = msg;
      if (msg) setTimeout(() => { if (statusMsg.textContent === msg) statusMsg.textContent = ""; }, 4000);
    }

    function timeAgo(ts: number): string {
      const diff = Date.now() - ts;
      const min = Math.floor(diff / 60000);
      if (min < 1) return "just now";
      if (min < 60) return `${min}m ago`;
      const h = Math.floor(min / 60);
      if (h < 24) return `${h}h ago`;
      const d = Math.floor(h / 24);
      if (d < 30) return `${d}d ago`;
      return new Date(ts).toLocaleDateString();
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function cardHtml(e: GalleryEntry): string {
      const thumb = e.thumbnailSvg ?? `<div class="flex h-full items-center justify-center text-xs text-ink-subtle">no preview</div>`;
      const safeName = escapeHtml(e.name);
      const sandboxHref = `/sandbox#${encodeCircuit(e.circuit)}`;
      return `
        <li class="rounded-lg border border-line bg-surface-elevated p-3 flex flex-col gap-3" data-id="${e.id}">
          <a href="${sandboxHref}" class="block aspect-[5/2] overflow-hidden rounded border border-line bg-surface-sunken hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent">
            ${thumb}
          </a>
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-ink" title="${safeName}">${safeName}</p>
              <p class="text-xs text-ink-subtle font-mono">${e.qubits}q · ${e.steps} steps · ${timeAgo(e.updatedAt)}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            <a href="${sandboxHref}" class="rounded border border-line-strong bg-surface px-2 py-1 text-xs text-ink hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent">Open</a>
            <button type="button" data-action="rename" class="rounded border border-line-strong bg-surface px-2 py-1 text-xs text-ink hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent">Rename</button>
            <button type="button" data-action="duplicate" class="rounded border border-line-strong bg-surface px-2 py-1 text-xs text-ink hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent">Duplicate</button>
            <button type="button" data-action="copy" class="rounded border border-line-strong bg-surface px-2 py-1 text-xs text-ink hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent">Copy link</button>
            <button type="button" data-action="delete" class="rounded border border-warning/40 bg-warning/5 px-2 py-1 text-xs text-warning hover:bg-warning/15 focus:outline-none focus:ring-2 focus:ring-warning">Delete</button>
          </div>
        </li>
      `;
    }

    async function render(): Promise<void> {
      if (!grid || !empty) return;
      const entries = await loadAll();
      if (fallbackBanner) fallbackBanner.classList.toggle("hidden", !usingFallback());
      if (quotaBanner) quotaBanner.classList.toggle("hidden", entries.length < 100);
      if (entries.length === 0) {
        grid.innerHTML = "";
        empty.classList.remove("hidden");
        return;
      }
      empty.classList.add("hidden");
      grid.innerHTML = entries.map(cardHtml).join("");
    }

    grid?.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action]");
      if (!btn) return;
      const li = btn.closest<HTMLElement>("[data-id]");
      if (!li) return;
      const id = li.dataset.id!;
      const action = btn.dataset.action!;
      if (action === "delete") {
        if (!confirm("Delete this circuit? This cannot be undone.")) return;
        await deleteOne(id);
        setStatus("Deleted.");
        await render();
      } else if (action === "rename") {
        const next = prompt("New name:");
        if (next && next.trim()) {
          await renameOne(id, next.trim());
          setStatus("Renamed.");
          await render();
        }
      } else if (action === "duplicate") {
        await duplicate(id);
        setStatus("Duplicated.");
        await render();
      } else if (action === "copy") {
        const a = li.querySelector<HTMLAnchorElement>("a[href^='/sandbox#']");
        if (a) {
          const url = new URL(a.href, location.origin).href;
          try {
            await navigator.clipboard.writeText(url);
            setStatus("Link copied.");
          } catch {
            setStatus("Couldn't copy — selecting the URL instead.");
            window.prompt("Copy this link:", url);
          }
        }
      }
    });

    document.querySelector('[data-role="export-btn"]')?.addEventListener("click", async () => {
      const bundle = await exportAll();
      const json = JSON.stringify(bundle, null, 2);
      const blob = new Blob([json], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      const ts = new Date().toISOString().replace(/[:.]/g, "-").slice(0, 19);
      a.href = url;
      a.download = `quantum-gallery-${ts}.json`;
      a.click();
      URL.revokeObjectURL(url);
      setStatus(`Exported ${bundle.entries.length} entries.`);
    });

    document.querySelector<HTMLInputElement>('[data-role="import-input"]')?.addEventListener("change", async (e) => {
      const input = e.target as HTMLInputElement;
      const file = input.files?.[0];
      if (!file) return;
      try {
        const text = await file.text();
        const parsed = JSON.parse(text);
        const mergeMode = confirm("OK = merge with existing entries (recommended).\nCancel = REPLACE everything with this file's entries.");
        const result = await importMany(parsed, mergeMode ? "merge" : "replace");
        setStatus(`Imported ${result.added} new, ${result.skipped} updated${result.errors.length ? `, ${result.errors.length} skipped` : ""}.`);
        await render();
      } catch (err) {
        setStatus("Import failed — not valid JSON.");
      } finally {
        input.value = "";
      }
    });

    document.querySelector('[data-role="clear-btn"]')?.addEventListener("click", async () => {
      if (!confirm("Permanently delete ALL saved circuits? Export first if you want a backup.")) return;
      await clear();
      setStatus("Gallery cleared.");
      await render();
    });

    // re-render on cross-event store updates (save drawer in sandbox)
    subscribe(() => { render(); });

    render();
  </script>
</EssayLayout>
