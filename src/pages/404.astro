---
import "../styles/theme.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import { BOOTSTRAP_SCRIPT } from "../lib/themeBootstrap";
/**
 * Friendly 404 page. Theme-aware via shared semantic tokens.
 */
const title = "404 — page not found · Quantum";
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline set:html={BOOTSTRAP_SCRIPT} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
  </head>
  <body class="bg-surface text-ink antialiased">
    <div class="fixed top-4 right-4 z-50">
      <ThemeToggle />
    </div>
    <main class="mx-auto max-w-2xl px-6 py-24 text-center">
      <p class="mb-4 text-sm uppercase tracking-widest text-accent">404</p>
      <h1 class="mb-5 text-4xl sm:text-5xl font-semibold leading-tight">
        That page collapsed into the void.
      </h1>
      <p class="mb-10 text-lg text-ink-muted">
        Quantum mechanics says the page might exist somewhere in the
        multiverse. Classical web hosting says: nope, not here.
      </p>

      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <a
          href="/"
          class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-emphasis focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >← Back to the map</a>
        <a
          href="/qubit"
          class="rounded-md border border-accent/40 bg-accent-muted/30 px-4 py-2 text-sm font-medium text-accent hover:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >Start with the qubit essay</a>
        <a
          href="/sandbox"
          class="rounded-md border border-positive/40 bg-positive/10 px-4 py-2 text-sm font-medium text-positive hover:border-positive focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-positive"
        >Jump into the sandbox</a>
      </div>

      <p class="text-sm text-ink-subtle">
        If you got here from a link on this site, that's a bug — please
        let us know on GitHub.
      </p>
    </main>
  </body>
</html>
