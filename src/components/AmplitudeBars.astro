---
/**
 * AmplitudeBars — signed-amplitude SVG bar chart with Grover-specific
 * iterator controls.
 *
 * Why a new widget instead of reusing `ProbabilityBars`:
 *   - The pedagogical lesson in ALG-04 is the SIGN flip. Squaring to
 *     probability hides it. We need a zero axis with positive bars
 *     above and negative bars below so the oracle moment is visible.
 *   - The control surface is Grover-specific (marked-state dropdown,
 *     iteration scrubber with optimal `k_opt` badge, overshoot
 *     override). Bolting that onto an existing stepper would muddy both.
 *
 * The page emits a precomputed sequence per marked state into
 * `data-snapshots-by-marked`. The client never imports the simulator
 * — it just swaps which sequence to render when the dropdown changes.
 * That keeps the widget cheap (still under 4 KB of eager JS) and
 * leaves all quantum math owned by `src/lib/quantum/grover.ts`.
 */
import type { GroverSnapshot } from "../lib/quantum/grover";

interface Props {
  /**
   * Precomputed snapshot sequences keyed by marked basis index. The
   * page builds these at frontmatter time so the client script stays
   * simulator-free.
   */
  snapshotsByMarked: Record<number, GroverSnapshot[]>;
  /** Initially selected marked basis index. */
  markedIndex: number;
  /** Qubit count (1–4); used for label width + dropdown population. */
  qubits: number;
  caption?: string;
  /**
   * Largest iteration the numeric override may reach. Defaults to the
   * length of the longest provided sequence minus 1.
   */
  maxIterations?: number;
}

const {
  snapshotsByMarked,
  markedIndex,
  qubits,
  caption,
  maxIterations,
} = Astro.props as Props;

const N = 1 << qubits;
const labelWidth = qubits;
const basisOptions = Array.from({ length: N }, (_, i) => ({
  value: i,
  label: `|${i.toString(2).padStart(labelWidth, "0")}⟩`,
}));

const allSequences = Object.values(snapshotsByMarked);
const computedMax = allSequences.reduce(
  (acc, seq) => Math.max(acc, seq.length - 1),
  0,
);
const cap = typeof maxIterations === "number" ? maxIterations : computedMax;

const initialSequence = snapshotsByMarked[markedIndex] ?? [];
const initialIteration = 0;
const initialSnapshot = initialSequence[initialIteration];

// k_opt is the optimal iteration count for the current N. Derived
// from sequence length only when the page didn't precompute extras;
// `floor((pi/4)*sqrt(N))` is the textbook formula. Recomputed
// client-side too so the badge stays in sync as marked changes.
const kOpt = Math.floor((Math.PI / 4) * Math.sqrt(N));

const initialReadout = initialSnapshot
  ? `${basisOptions[markedIndex].label}, iteration ${initialIteration} of ${kOpt}, P(marked) = ${initialSnapshot.markedProbability.toFixed(3)}`
  : "";
---

<figure
  class="my-6 rounded-lg border border-line bg-surface-elevated/40 p-5 space-y-3"
  data-widget="amplitude-bars"
  data-qubits={qubits}
  data-marked-index={markedIndex}
  data-k-opt={kOpt}
  data-max-iterations={cap}
  data-snapshots-by-marked={JSON.stringify(snapshotsByMarked)}
  tabindex="0"
>
  {caption && (
    <figcaption class="text-sm text-ink-subtle">{caption}</figcaption>
  )}

  <div class="flex flex-wrap items-center gap-3 text-sm">
    <label class="flex items-center gap-2">
      <span class="text-ink-muted">Marked state</span>
      <select
        data-action="marked"
        class="rounded-md border border-line-strong bg-surface-sunken/60 px-2 py-1 font-mono text-xs text-ink-emphasis focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {basisOptions.map((opt) => (
          <option value={opt.value} selected={opt.value === markedIndex}>
            {opt.label}
          </option>
        ))}
      </select>
    </label>
    <label class="flex items-center gap-2">
      <span class="text-ink-muted">Iterations</span>
      <input
        type="number"
        data-action="override"
        min="0"
        max={cap}
        step="1"
        value={initialIteration}
        class="w-20 rounded-md border border-line-strong bg-surface-sunken/60 px-2 py-1 font-mono text-xs text-ink-emphasis tabular-nums focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      />
    </label>
    <p
      data-role="k-indicator"
      class="font-mono text-xs text-ink-subtle tabular-nums"
    >
      k = <span data-role="k-current">{initialIteration}</span> / k_opt = <span data-role="k-opt">{kOpt}</span>
    </p>
  </div>

  <div class="relative">
    <svg
      class="w-full h-48"
      viewBox="0 0 480 200"
      role="img"
      aria-label="Signed amplitude bars (Grover iteration scrubber)"
      data-role="chart"
    ></svg>
    <p
      class="mt-2 text-xs text-ink-subtle"
      data-role="readout"
      aria-live="polite"
    >
      {initialReadout}
    </p>
  </div>

  <div class="flex items-center justify-between gap-3">
    <button
      type="button"
      data-action="prev"
      class="rounded-md border border-line-strong bg-surface-sunken/60 px-3 py-1.5 text-sm text-ink-muted hover:bg-line-strong disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent transition-colors"
      aria-label="Previous iteration"
      disabled
      aria-disabled="true"
    >
      ← Prev
    </button>
    <button
      type="button"
      data-action="reset"
      class="rounded-md border border-line-strong bg-surface-sunken/60 px-3 py-1.5 text-sm text-ink-muted hover:bg-line-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent transition-colors"
      aria-label="Reset to iteration 0"
    >
      Reset
    </button>
    <button
      type="button"
      data-action="next"
      class="rounded-md border border-accent/40 bg-accent/10 px-3 py-1.5 text-sm font-mono text-accent-emphasis hover:bg-accent/20 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent transition-colors"
      aria-label="Next iteration"
    >
      Next →
    </button>
  </div>
</figure>

<script>
  interface GroverSnapshot {
    iteration: number;
    amplitudes: number[];
    probabilities: number[];
    markedIndex: number;
    markedProbability: number;
    basisLabels: string[];
  }

  const reduceMotion =
    typeof window !== "undefined" &&
    window.matchMedia &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const VIEWBOX_W = 480;
  const VIEWBOX_H = 200;
  const PADDING_X = 24;
  const ZERO_Y = VIEWBOX_H / 2;
  const HALF_BAR_H = VIEWBOX_H / 2 - 28;

  function optimalGroverIterations(N: number): number {
    return Math.floor((Math.PI / 4) * Math.sqrt(N));
  }

  function mount(el: HTMLElement) {
    const qubits = Number(el.dataset.qubits ?? "1");
    const N = 1 << qubits;
    const maxIter = Number(el.dataset.maxIterations ?? "0");

    let snapshotsByMarked: Record<string, GroverSnapshot[]>;
    try {
      snapshotsByMarked = JSON.parse(el.dataset.snapshotsByMarked ?? "{}");
    } catch {
      console.warn("AmplitudeBars: could not parse data-snapshots-by-marked", el);
      return;
    }

    let marked = Number(el.dataset.markedIndex ?? "0");
    let iteration = 0;
    let kOpt = optimalGroverIterations(N);

    const svg = el.querySelector<SVGSVGElement>('[data-role="chart"]')!;
    const readout = el.querySelector<HTMLElement>('[data-role="readout"]')!;
    const kCurrentEl = el.querySelector<HTMLElement>('[data-role="k-current"]')!;
    const kOptEl = el.querySelector<HTMLElement>('[data-role="k-opt"]')!;
    const overrideInput = el.querySelector<HTMLInputElement>('[data-action="override"]')!;
    const markedSelect = el.querySelector<HTMLSelectElement>('[data-action="marked"]')!;
    const prevBtn = el.querySelector<HTMLButtonElement>('[data-action="prev"]')!;
    const nextBtn = el.querySelector<HTMLButtonElement>('[data-action="next"]')!;
    const resetBtn = el.querySelector<HTMLButtonElement>('[data-action="reset"]')!;

    const sequenceFor = (m: number): GroverSnapshot[] =>
      snapshotsByMarked[String(m)] ?? [];

    const buildBars = (n: number) => {
      svg.innerHTML = "";
      // Zero axis.
      const axis = document.createElementNS("http://www.w3.org/2000/svg", "line");
      axis.setAttribute("x1", String(PADDING_X));
      axis.setAttribute("x2", String(VIEWBOX_W - PADDING_X));
      axis.setAttribute("y1", String(ZERO_Y));
      axis.setAttribute("y2", String(ZERO_Y));
      axis.setAttribute("stroke", "currentColor");
      axis.setAttribute("stroke-opacity", "0.4");
      axis.setAttribute("stroke-width", "1");
      svg.appendChild(axis);

      const barWidth = (VIEWBOX_W - PADDING_X * 2) / n - 4;
      const bars: SVGRectElement[] = [];
      const labels: SVGTextElement[] = [];
      for (let i = 0; i < n; i++) {
        const x = PADDING_X + i * (barWidth + 4);
        const rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        rect.classList.add("bar");
        rect.dataset.idx = String(i);
        rect.setAttribute("x", String(x));
        rect.setAttribute("width", String(barWidth));
        rect.setAttribute("rx", "2");
        if (!reduceMotion) {
          rect.style.transition = "height 220ms ease-out, y 220ms ease-out, fill 220ms";
        }
        svg.appendChild(rect);
        bars.push(rect);

        const label = document.createElementNS("http://www.w3.org/2000/svg", "text");
        label.classList.add("label");
        label.dataset.idx = String(i);
        label.setAttribute("x", String(x + barWidth / 2));
        label.setAttribute("y", String(VIEWBOX_H - 4));
        label.setAttribute("text-anchor", "middle");
        label.setAttribute("fill", "currentColor");
        label.setAttribute("fill-opacity", "0.65");
        label.setAttribute("font-size", n > 8 ? "9" : "11");
        label.setAttribute("font-family", "ui-monospace, monospace");
        label.textContent = `|${i.toString(2).padStart(qubits, "0")}⟩`;
        svg.appendChild(label);
        labels.push(label);
      }
      return { bars, labels };
    };

    let { bars, labels } = buildBars(N);

    const render = () => {
      const seq = sequenceFor(marked);
      if (seq.length === 0) return;
      const snap = seq[Math.min(iteration, seq.length - 1)];
      const amps = snap.amplitudes;

      for (let i = 0; i < bars.length; i++) {
        const a = amps[i] ?? 0;
        const isMarked = i === marked;
        const isNegative = a < 0;
        const h = Math.min(1, Math.abs(a)) * HALF_BAR_H;
        bars[i].setAttribute("height", String(h));
        bars[i].setAttribute("y", String(isNegative ? ZERO_Y : ZERO_Y - h));
        // Use opacity + accent ring (not color alone) to encode sign.
        bars[i].setAttribute(
          "fill",
          isMarked ? "#fbbf24" : isNegative ? "#f472b6" : "#818cf8",
        );
        bars[i].setAttribute("stroke", isMarked ? "#facc15" : "none");
        bars[i].setAttribute("stroke-width", isMarked ? "1.5" : "0");
        labels[i].setAttribute("font-weight", isMarked ? "700" : "400");
      }

      const markedLabel = `|${marked.toString(2).padStart(qubits, "0")}⟩`;
      readout.textContent = `${markedLabel}, iteration ${snap.iteration} of ${kOpt}, P(marked) = ${snap.markedProbability.toFixed(3)}`;
      kCurrentEl.textContent = String(snap.iteration);
      kOptEl.textContent = String(kOpt);
      overrideInput.value = String(iteration);

      const atStart = iteration === 0;
      const atEnd = iteration === seq.length - 1;
      prevBtn.disabled = atStart;
      nextBtn.disabled = atEnd;
      prevBtn.setAttribute("aria-disabled", String(atStart));
      nextBtn.setAttribute("aria-disabled", String(atEnd));
    };

    const setIteration = (next: number) => {
      const seq = sequenceFor(marked);
      const limit = Math.max(0, Math.min(seq.length - 1, maxIter));
      iteration = Math.max(0, Math.min(limit, next));
      render();
    };

    el.addEventListener("click", (event) => {
      const target = (event.target as HTMLElement).closest("button");
      if (!target || !el.contains(target)) return;
      if (target.dataset.action === "prev") setIteration(iteration - 1);
      else if (target.dataset.action === "next") setIteration(iteration + 1);
      else if (target.dataset.action === "reset") setIteration(0);
    });

    markedSelect.addEventListener("change", (event) => {
      const next = Number((event.target as HTMLSelectElement).value);
      if (!Number.isInteger(next) || next < 0 || next >= N) return;
      marked = next;
      iteration = 0;
      render();
    });

    overrideInput.addEventListener("input", (event) => {
      const raw = Number((event.target as HTMLInputElement).value);
      if (!Number.isFinite(raw)) return;
      setIteration(Math.floor(raw));
    });

    el.addEventListener("keydown", (event) => {
      const tag = (event.target as HTMLElement).tagName;
      if (tag === "INPUT" || tag === "SELECT") return;
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        setIteration(iteration - 1);
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        setIteration(iteration + 1);
      }
    });

    render();
  }

  document
    .querySelectorAll<HTMLElement>('[data-widget="amplitude-bars"]')
    .forEach(mount);
</script>
