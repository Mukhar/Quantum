---
/**
 * MathNerds — inline collapsible for chalkboard math, droppable anywhere
 * in essay prose. Use this for *section-local* math appendices; use the
 * EssayLayout `math-nerds` slot for the *page-global* one.
 *
 * Style intentionally mirrors EssayLayout's global appendix for visual
 * consistency, but each instance stands alone.
 */

interface Props {
  /** Heading shown on the collapsible. Default: "For the math nerds". */
  title?: string;
}

const { title = "For the math nerds" } = Astro.props as Props;
---

<details class="my-6 rounded-lg border border-line bg-surface-elevated/40 p-4">
  <summary class="cursor-pointer text-sm uppercase tracking-widest text-accent hover:text-accent">
    {title}
  </summary>
  <div class="mt-3 space-y-3 text-ink">
    <slot />
  </div>
</details>
