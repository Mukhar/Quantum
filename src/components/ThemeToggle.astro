---
/**
 * ThemeToggle — 3-state header button: Light → Dark → System → Light.
 *
 * Persists to localStorage["quantum/theme"] via src/lib/theme.ts.
 * Reads its initial state on mount; cycles on click. Dispatches
 * `themechange` on `window` for canvas/3D widgets that paint outside CSS.
 *
 * Zero hydration cost at build-time — the component renders a single
 * <button>; the inline <script> wires up behavior only after load.
 */
---

<button
  type="button"
  id="quantum-theme-toggle"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-line text-ink-muted hover:text-ink hover:border-line-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent transition-colors"
  aria-label="Switch theme"
  title="Theme: system"
>
  {/* Three icons stacked; CSS hides 2 of 3 based on data-state. */}
  <svg
    data-icon="light"
    class="h-4 w-4 hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg
    data-icon="dark"
    class="h-4 w-4 hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <svg
    data-icon="system"
    class="h-4 w-4 hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="3" y="4" width="18" height="12" rx="2"></rect>
    <path d="M8 20h8M12 16v4"></path>
  </svg>
</button>

<script>
  import {
    applyTheme,
    getStoredTheme,
    nextInCycle,
    subscribeToSystemTheme,
    type Theme,
  } from "../lib/theme";

  const LABELS: Record<Theme, string> = {
    light: "Light theme — click for dark",
    dark: "Dark theme — click for system",
    system: "System theme — click for light",
  };

  function render(btn: HTMLButtonElement, theme: Theme): void {
    btn.setAttribute("aria-label", LABELS[theme]);
    btn.setAttribute("title", `Theme: ${theme}`);
    btn.querySelectorAll<SVGElement>("svg[data-icon]").forEach((svg) => {
      svg.classList.toggle("hidden", svg.dataset.icon !== theme);
    });
  }

  function init(): void {
    const btn = document.getElementById(
      "quantum-theme-toggle",
    ) as HTMLButtonElement | null;
    if (!btn) return;

    let current = getStoredTheme();
    render(btn, current);

    btn.addEventListener("click", () => {
      current = nextInCycle(current);
      applyTheme(current);
      render(btn, current);
    });

    // If the user is on "system" and the OS theme flips, the bootstrap +
    // theme.ts subscription already re-paint; we only need to refresh
    // our icon. (The icon stays "system" — it's the effective theme that
    // changed, not the preference.)
    subscribeToSystemTheme(() => render(btn, current));
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
