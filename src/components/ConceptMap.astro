---
/**
 * ConceptMap — homepage nav.
 *
 * Design constraints:
 *  - Hand-rolled SVG, no D3, no graph library. At ~10 nodes in v1
 *    a programmatic layout would cost more than placing nodes by hand.
 *  - Every live node is an <a> with a visible focus ring (WCAG 2.2 AA).
 *  - Mobile (< 640 px) falls back to a stacked <ol> — the SVG is
 *    `sm:block hidden`, the list is `sm:hidden block`. Same hrefs,
 *    zero feature drift.
 *  - v2 placeholders (CNOT+Bell, Deutsch) render as <div> not <a>,
 *    `aria-disabled="true"`, dimmed slate, no hover state.
 *
 * Edge layout: the linear reading path runs across the top in a
 * single row. Sandbox and Challenges sit underneath as utility nodes
 * connected to qubit (entry) and entanglement (exit). v2 placeholders
 * float on a third row, dimmed.
 *
 * Sizes assume a 1100×360 viewBox. The SVG scales to its container
 * (max-width: 1100 px) and never exceeds 360 px tall, so it fits
 * inside the 65vh hero region without scrolling on a laptop.
 */

interface Node {
  /** href; null marks a v2 placeholder (renders as div). */
  href: string | null;
  label: string;
  /** Center x in SVG units. */
  cx: number;
  cy: number;
  /** Visual tier: primary (essays), utility (sandbox/challenges), v2 (dimmed). */
  tier: "primary" | "utility" | "v2";
}

const NODE_W = 150;
const NODE_H = 56;
const NODE_R = 10;

// Top row: 5 foundations essays (qubit -> entanglement).
// Middle row: sandbox + challenges utility nodes.
// Bottom row: 5 algorithm essays (cnot-bell -> deutsch -> teleportation -> superdense -> grover).
// Plan 02-05 adds Teleportation; its reading-path edge wraps from
// deutsch (rightmost row-3 node) back left to teleportation (leftmost),
// signalling the start of the applications track. Plan 04 (Grover)
// extends the applications track rightward after teleportation.
// v3 Phase 3 (Superdense) slots in between teleportation and grover —
// completes the communication arc. Grover shifts one slot right to
// keep the row spacing even.
const nodes: Node[] = [
  { href: "/qubit",          label: "Qubit",          cx: 100,  cy: 60,  tier: "primary" },
  { href: "/superposition",  label: "Superposition",  cx: 290,  cy: 60,  tier: "primary" },
  { href: "/measurement",    label: "Measurement",    cx: 480,  cy: 60,  tier: "primary" },
  { href: "/gates",          label: "Gates",          cx: 670,  cy: 60,  tier: "primary" },
  { href: "/entanglement",   label: "Entanglement",   cx: 860,  cy: 60,  tier: "primary" },
  { href: "/sandbox",        label: "Sandbox",        cx: 380,  cy: 190, tier: "utility" },
  { href: "/sandbox/challenges", label: "Challenges", cx: 580,  cy: 190, tier: "utility" },
  { href: "/cnot-bell",      label: "CNOT + Bell",    cx: 670,  cy: 310, tier: "primary" },
  { href: "/deutsch",        label: "Deutsch",        cx: 860,  cy: 310, tier: "primary" },
  { href: "/teleportation",  label: "Teleportation",  cx: 100,  cy: 310, tier: "primary" },
  { href: "/superdense-coding", label: "Superdense",  cx: 290,  cy: 310, tier: "primary" },
  { href: "/grover",         label: "Grover",         cx: 480,  cy: 310, tier: "primary" },
];

// Directed edges: from-node index -> to-node index. Indices match `nodes`.
// Reading-path edges (0..4 -> 7 -> 8 -> 9 -> 10 -> 11), plus utility entry/exit
// (qubit/deutsch -> sandbox, qubit/deutsch -> challenges).
const edges: Array<{ from: number; to: number; dim?: boolean }> = [
  { from: 0, to: 1 },
  { from: 1, to: 2 },
  { from: 2, to: 3 },
  { from: 3, to: 4 },
  { from: 4, to: 7 },
  { from: 7, to: 8 },
  { from: 8, to: 9 },
  { from: 9, to: 10 },
  { from: 10, to: 11 },
  { from: 0, to: 5 },
  { from: 8, to: 5 },
  { from: 0, to: 6 },
  { from: 8, to: 6 },
];

function nodeFill(tier: Node["tier"]): string {
  // Semantic CSS vars so map repaints on theme toggle. Each tier picks
  // the appropriate surface level — primary = elevated, utility = positive
  // tinted, dim = sunken so it visibly recedes.
  if (tier === "primary") return "rgb(var(--color-surface-elevated))";
  if (tier === "utility") return "rgb(var(--color-positive) / 0.15)";
  return "rgb(var(--color-surface-sunken))";
}
function nodeStroke(tier: Node["tier"]): string {
  if (tier === "primary") return "rgb(var(--color-accent))";
  if (tier === "utility") return "rgb(var(--color-positive))";
  return "rgb(var(--color-line-strong))";
}
function nodeText(tier: Node["tier"]): string {
  if (tier === "primary") return "rgb(var(--color-ink))";
  if (tier === "utility") return "rgb(var(--color-positive))";
  return "rgb(var(--color-ink-subtle))";
}

/** Build a smooth cubic Bezier between two nodes, edge-to-edge. */
function edgePath(a: Node, b: Node): string {
  const x1 = a.cx;
  const y1 = a.cy + (b.cy > a.cy ? NODE_H / 2 : -NODE_H / 2);
  const x2 = b.cx;
  const y2 = b.cy + (b.cy > a.cy ? -NODE_H / 2 : NODE_H / 2);
  const dy = (y2 - y1) * 0.55;
  return `M ${x1} ${y1} C ${x1} ${y1 + dy}, ${x2} ${y2 - dy}, ${x2} ${y2}`;
}
---

<nav aria-label="Site concept map" class="not-prose">
  <!-- Desktop / tablet SVG map -->
  <svg
    role="img"
    aria-label="Visual map of the Quantum site: 10 essays in reading order (5 foundations + 5 algorithm), with sandbox and challenges as utility entry points"
    viewBox="0 0 1000 360"
    class="hidden sm:block w-full max-w-[1100px] mx-auto h-auto"
  >
    <defs>
      <marker
        id="concept-arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" style="fill: rgb(var(--color-ink-subtle))" />
      </marker>
      <marker
        id="concept-arrow-dim"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" style="fill: rgb(var(--color-line-strong))" />
      </marker>
    </defs>

    {edges.map((e) => (
      <path
        d={edgePath(nodes[e.from], nodes[e.to])}
        fill="none"
        style={`stroke: ${e.dim ? "rgb(var(--color-line-strong))" : "rgb(var(--color-ink-subtle))"}`}
        stroke-width="1.5"
        stroke-dasharray={e.dim ? "4 4" : "0"}
        marker-end={e.dim ? "url(#concept-arrow-dim)" : "url(#concept-arrow)"}
      />
    ))}

    {nodes.map((n) => {
      const x = n.cx - NODE_W / 2;
      const y = n.cy - NODE_H / 2;
      const common = (
        <g>
          <rect
            x={x}
            y={y}
            width={NODE_W}
            height={NODE_H}
            rx={NODE_R}
            style={`fill: ${nodeFill(n.tier)}; stroke: ${nodeStroke(n.tier)};`}
            stroke-width="1.5"
          />
          <text
            x={n.cx}
            y={n.cy + 5}
            text-anchor="middle"
            font-family="ui-sans-serif, system-ui, sans-serif"
            font-size="16"
            font-weight="500"
            style={`fill: ${nodeText(n.tier)};`}
          >{n.label}{n.tier === "v2" ? " · v2" : ""}</text>
        </g>
      );

      if (n.href) {
        return (
          <a
            href={n.href}
            class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            aria-label={`Read: ${n.label}`}
          >{common}</a>
        );
      }
      return (
        <g aria-disabled="true" aria-label={`${n.label} (coming in v2)`}>
          {common}
        </g>
      );
    })}
  </svg>

  <!-- Mobile fallback: stacked list, same hrefs -->
  <ol class="sm:hidden flex flex-col gap-3 not-prose">
    {nodes.filter((n) => n.tier === "primary").map((n, i) => (
      <li>
        <a
          href={n.href!}
          class="flex items-baseline gap-3 rounded-md border border-line bg-surface-elevated/60 px-4 py-3 hover:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          <span class="text-xs uppercase tracking-widest text-accent tabular-nums">{String(i + 1).padStart(2, "0")}</span>
          <span class="text-ink font-medium">{n.label}</span>
        </a>
      </li>
    ))}
    {nodes.filter((n) => n.tier === "utility").map((n) => (
      <li>
        <a
          href={n.href!}
          class="flex items-baseline gap-3 rounded-md border border-positive/40 bg-positive/10/30 px-4 py-3 hover:border-positive focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-positive"
        >
          <span class="text-xs uppercase tracking-widest text-positive">play</span>
          <span class="text-positive font-medium">{n.label}</span>
        </a>
      </li>
    ))}
    {nodes.filter((n) => n.tier === "v2").map((n) => (
      <li
        aria-disabled="true"
        class="flex items-baseline gap-3 rounded-md border border-line bg-surface/60 px-4 py-3"
      >
        <span class="text-xs uppercase tracking-widest text-ink-subtle">v2</span>
        <span class="text-ink-subtle">{n.label}</span>
      </li>
    ))}
  </ol>
</nav>
