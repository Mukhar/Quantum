---
/**
 * ResultsPanel — live multi-qubit readout for the sandbox.
 *
 * Renders one card per qubit (1–4 of them, sized by the circuit's
 * current qubit count) plus a global state-vector strip beneath.
 * Each card has three slots that `results.client.ts` hydrates:
 *
 *   1. A lightweight inline-SVG Bloch projection (no Three.js — the
 *      sandbox has up to four of these on screen and the panel must
 *      stay snappy at 60 Hz dragging).
 *   2. A horizontal P(|0⟩) / P(|1⟩) bar pair (marginal probabilities
 *      of the reduced density matrix's diagonal).
 *   3. An "entangled" badge that appears when r < 0.98 — meaning the
 *      single-qubit Bloch picture is lossy and the qubit shares
 *      information with at least one other.
 *
 * SSR emits the static chrome of all 4 possible cards (we hide unused
 * ones with the `data-qubit-card` attribute toggled by the hydrator).
 * This avoids layout shift when the user bumps the qubit count.
 */
---

<section
  data-results-panel
  class="rounded-lg border border-slate-800 bg-slate-900/40 p-4 space-y-4"
  aria-label="Live circuit results"
>
  <header class="flex items-baseline justify-between">
    <h2 class="text-slate-100 font-medium">Results</h2>
    <p
      data-role="status"
      class="text-xs text-slate-500"
      aria-live="polite"
    >Idle</p>
  </header>

  <div
    data-role="cards"
    class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4"
  >
    {[0, 1, 2, 3].map((q) => (
      <article
        data-qubit-card={q}
        class="rounded-md border border-slate-800 bg-slate-950/60 p-3 space-y-2 hidden"
        aria-label={`Qubit ${q} readout`}
      >
        <div class="flex items-center justify-between">
          <p class="font-mono text-xs uppercase tracking-wider text-slate-400">
            q<span class="text-indigo-300">{q}</span>
          </p>
          <span
            data-role="entangled-badge"
            class="hidden rounded-full bg-amber-500/15 text-amber-300 text-[10px] uppercase tracking-wider px-2 py-0.5"
            title="This qubit shares information with another — no single-qubit picture is exact."
          >Entangled</span>
        </div>

        <div class="relative aspect-square w-full">
          <svg
            data-role="bloch"
            viewBox="0 0 100 100"
            class="w-full h-full"
            role="img"
            aria-label={`Bloch projection for qubit ${q}`}
          >
            <!-- circle outline + axes -->
            <circle cx="50" cy="50" r="40" fill="none" stroke="#334155" stroke-width="1" />
            <line x1="50" y1="10" x2="50" y2="90" stroke="#1e293b" stroke-width="1" />
            <line x1="10" y1="50" x2="90" y2="50" stroke="#1e293b" stroke-width="1" />
            <text x="50" y="8" text-anchor="middle" font-size="6" fill="#64748b" font-family="ui-monospace, monospace">|0⟩</text>
            <text x="50" y="97" text-anchor="middle" font-size="6" fill="#64748b" font-family="ui-monospace, monospace">|1⟩</text>
            <!-- arrow, hydrated by the client -->
            <line
              data-role="arrow"
              x1="50" y1="50" x2="50" y2="10"
              stroke="#818cf8" stroke-width="2.5" stroke-linecap="round"
            />
            <circle
              data-role="tip"
              cx="50" cy="10" r="3"
              fill="#818cf8"
            />
          </svg>
        </div>

        <div class="space-y-1 font-mono text-[11px] text-slate-400">
          <div class="flex items-center gap-2">
            <span class="w-8 text-right text-slate-500">P|0⟩</span>
            <div class="flex-1 h-2 rounded-sm bg-slate-800 overflow-hidden">
              <div data-role="p0-bar" class="h-full bg-indigo-400" style="width: 100%"></div>
            </div>
            <span data-role="p0-text" class="w-12 text-right tabular-nums">1.000</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-8 text-right text-slate-500">P|1⟩</span>
            <div class="flex-1 h-2 rounded-sm bg-slate-800 overflow-hidden">
              <div data-role="p1-bar" class="h-full bg-rose-400" style="width: 0%"></div>
            </div>
            <span data-role="p1-text" class="w-12 text-right tabular-nums">0.000</span>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div
    data-role="state-vector"
    class="rounded-md bg-slate-950/60 border border-slate-800 p-3 overflow-x-auto"
  >
    <p class="text-[10px] uppercase tracking-wider text-slate-500 mb-1">Global state |ψ⟩</p>
    <pre
      data-role="state-readout"
      class="font-mono text-xs text-indigo-200 whitespace-pre-wrap leading-relaxed m-0"
    >|0…0⟩</pre>
  </div>
</section>
