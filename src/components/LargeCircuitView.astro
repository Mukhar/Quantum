---
/**
 * LargeCircuitView — static renderer for >4-qubit Shor-style diagrams.
 *
 * Why this is a separate component from CircuitView:
 *
 *   - CircuitView.astro consumes sandbox `Circuit` and calls both
 *     `encodeCircuit()` and `toQiskit()` at SSR. Both reject anything
 *     above MAX_QUBITS = 4. Phase 5b PHASE-CONTEXT D-16 says: do NOT
 *     weaken that cap or mutate the sandbox Op vocabulary just to draw
 *     Shor-15.
 *
 *   - The N=15 Shor diagram needs 8 qubits, controlled-phase rotations,
 *     SWAPs, and labeled multi-qubit modular-exponentiation blocks —
 *     none of which exist in the sandbox IR.
 *
 *   - The honest framing is "you built the engine here; now run the
 *     real thing in Qiskit." The Copy button is the prominent CTA and
 *     there is intentionally NO "Remix in sandbox" link (D-15).
 *
 * Visual language:
 *   - Reuses the same color families CircuitView uses for H, phase,
 *     and measure cells so readers see continuity across essays.
 *   - Adds outlined "block" rectangles for modular-exp subroutines and
 *     bands behind the steps to mark grouped sections (init, modexp,
 *     iqft, measure) with captions in the figcaption area.
 *   - Mobile: SVG is `width="100%"` with `aria-label`; the host
 *     container scrolls horizontally with a labeled affordance when
 *     the natural width exceeds the viewport.
 */
import { toQiskitShor15, type ShorStaticCircuit, type StaticCircuitOp } from "../lib/quantum";

interface Props {
  circuit: ShorStaticCircuit;
  caption?: string;
  class?: string;
}

const { circuit, caption, class: extraClass = "" } = Astro.props as Props;

const N = circuit.qubits;
const S = circuit.steps.length;

// Geometry — wider step width than CircuitView so block labels fit.
const LABEL_W = 56;
const STEP_W = 80;
const ROW_H = 40;
const PAD = 16;
const GATE_W = 40;
const GATE_H = 28;
const BLOCK_PAD = 6;

const width = LABEL_W + S * STEP_W + PAD * 2;
const height = PAD * 2 + N * ROW_H;

const cx = (t: number) => LABEL_W + PAD + t * STEP_W + STEP_W / 2;
const cy = (q: number) => PAD + q * ROW_H + ROW_H / 2;

// Block bands behind the steps — one rectangle per logical section,
// labelled below the diagram. Drawn first so cells sit on top.
const blockBands = circuit.blocks.map((b) => {
  const [s0, s1] = b.steps;
  const [q0, q1] = b.qubits;
  const x = cx(s0) - STEP_W / 2 + BLOCK_PAD;
  const y = cy(q0) - ROW_H / 2 + 2;
  const w = (s1 - s0 + 1) * STEP_W - BLOCK_PAD * 2;
  const h = (q1 - q0 + 1) * ROW_H - 4;
  return { ...b, x, y, w, h };
});

// Cell-fill keyed off StaticCircuitOp.kind. Reused from CircuitView's
// palette where the meanings match (H = indigo, measure = amber).
function fillFor(op: StaticCircuitOp): string {
  switch (op.kind) {
    case "h":       return "rgb(67 56 202)";   // indigo-700
    case "cphase":  return "rgb(91 33 182)";   // violet-800
    case "block":   return "rgb(15 118 110)";  // teal-700
    case "swap":    return "transparent";
    case "measure": return "rgb(120 53 15)";   // amber-900
  }
}

// Register labels — the renderer draws "counting / work" hints in the
// left gutter so a reader can tell q0..q3 from q4..q7 at a glance.
const registerLabels = (q: number): { label: string; color: string } => {
  const [c0, c1] = circuit.registers.countingQubits;
  if (q >= c0 && q <= c1) return { label: `q${q}`, color: "rgb(186 230 253)" }; // sky-200
  return { label: `q${q}`, color: "rgb(254 215 170)" }; // orange-200 (work)
};

const a11yLabel = caption
  ? `Static Shor circuit diagram: ${caption}`
  : `Static Shor circuit diagram with ${N} qubits and ${S} steps`;

// Bake the Qiskit snippet at SSR — zero client JS cost for the
// exporter and the click handler is event-delegated below.
const qiskitText = toQiskitShor15(circuit);

// Classical wire — drawn under the counting register at the bottom,
// signalling that measurement outcomes flow into a 4-bit register.
const classicalY = height - PAD / 2;
---

<figure class:list={["not-prose my-6", extraClass]}>
  <div class="rounded-lg border border-line bg-surface-elevated/40 p-4">
    <div
      class="overflow-x-auto"
      role="region"
      aria-label="Scrollable circuit diagram — swipe or arrow-key horizontally to see the full circuit"
      tabindex="0"
    >
      <svg
        role="img"
        aria-label={a11yLabel}
        viewBox={`0 0 ${width} ${height + 16}`}
        class="w-full h-auto"
        style={`min-width: ${width}px; max-height: ${height + 24}px`}
      >
        <!-- Block bands behind everything else -->
        {blockBands.map((b) => (
          <g>
            <rect
              x={b.x}
              y={b.y}
              width={b.w}
              height={b.h}
              rx={6}
              fill="rgb(30 41 59 / 0.4)"
              stroke="rgb(71 85 105)"
              stroke-width="1"
              stroke-dasharray="3 3"
            />
            <text
              x={b.x + 6}
              y={b.y + 14}
              font-family="ui-sans-serif, system-ui, sans-serif"
              font-size="10"
              font-weight="600"
              fill="rgb(148 163 184)"
            >{b.label}</text>
          </g>
        ))}

        <!-- Qubit wire rows -->
        {Array.from({ length: N }, (_, q) => {
          const r = registerLabels(q);
          return (
            <g>
              <text
                x={LABEL_W - 8}
                y={cy(q) + 4}
                text-anchor="end"
                font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
                font-size="12"
                fill={r.color}
              >{r.label}</text>
              <line
                x1={LABEL_W}
                y1={cy(q)}
                x2={width - PAD}
                y2={cy(q)}
                stroke="rgb(71 85 105)"
                stroke-width="1.5"
              />
            </g>
          );
        })}

        <!-- Classical wire stub (drawn as double line under counting register) -->
        <line
          x1={LABEL_W}
          y1={classicalY}
          x2={width - PAD}
          y2={classicalY}
          stroke="rgb(100 116 139)"
          stroke-width="1"
          stroke-dasharray="4 3"
        />
        <text
          x={LABEL_W - 8}
          y={classicalY + 4}
          text-anchor="end"
          font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
          font-size="11"
          fill="rgb(148 163 184)"
        >c</text>

        <!-- Controlled-phase connector lines (drawn behind cells) -->
        {circuit.steps.map((step, t) =>
          step
            .filter((op): op is Extract<StaticCircuitOp, { kind: "cphase" }> => op.kind === "cphase")
            .map((op) => (
              <g>
                <line
                  x1={cx(t)}
                  y1={cy(op.control)}
                  x2={cx(t)}
                  y2={cy(op.target)}
                  stroke="rgb(148 163 184)"
                  stroke-width="1.5"
                />
                <circle
                  cx={cx(t)}
                  cy={cy(op.control)}
                  r={5}
                  fill="rgb(226 232 240)"
                  stroke="rgb(71 85 105)"
                  stroke-width="1"
                />
              </g>
            )),
        )}

        <!-- SWAP connectors (drawn as double-X marks linked by a line) -->
        {circuit.steps.map((step, t) =>
          step
            .filter((op): op is Extract<StaticCircuitOp, { kind: "swap" }> => op.kind === "swap")
            .map((op) => {
              const x = cx(t);
              const yA = cy(op.qubitA);
              const yB = cy(op.qubitB);
              return (
                <g>
                  <line x1={x} y1={yA} x2={x} y2={yB} stroke="rgb(148 163 184)" stroke-width="1.5" />
                  {[yA, yB].map((y) => (
                    <g>
                      <line x1={x - 6} y1={y - 6} x2={x + 6} y2={y + 6} stroke="rgb(226 232 240)" stroke-width="2" />
                      <line x1={x - 6} y1={y + 6} x2={x + 6} y2={y - 6} stroke="rgb(226 232 240)" stroke-width="2" />
                    </g>
                  ))}
                </g>
              );
            }),
        )}

        <!-- Per-cell rendering for h / cphase target / block / measure -->
        {circuit.steps.map((step, t) =>
          step.map((op) => {
            const x = cx(t);
            switch (op.kind) {
              case "h": {
                const y = cy(op.qubit);
                return (
                  <g>
                    <rect
                      x={x - GATE_W / 2}
                      y={y - GATE_H / 2}
                      width={GATE_W}
                      height={GATE_H}
                      rx={4}
                      fill={fillFor(op)}
                      stroke="rgb(148 163 184)"
                      stroke-width="1"
                    />
                    <text
                      x={x}
                      y={y + 4}
                      text-anchor="middle"
                      font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
                      font-size="13"
                      font-weight="600"
                      fill="rgb(241 245 249)"
                    >{op.label}</text>
                  </g>
                );
              }
              case "cphase": {
                const y = cy(op.target);
                return (
                  <g>
                    <rect
                      x={x - GATE_W / 2}
                      y={y - GATE_H / 2}
                      width={GATE_W}
                      height={GATE_H}
                      rx={4}
                      fill={fillFor(op)}
                      stroke="rgb(148 163 184)"
                      stroke-width="1"
                    />
                    <text
                      x={x}
                      y={y + 4}
                      text-anchor="middle"
                      font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
                      font-size="9"
                      font-weight="600"
                      fill="rgb(241 245 249)"
                    >{op.label}</text>
                  </g>
                );
              }
              case "block": {
                // Multi-qubit block: rectangle spanning min(qubits)..max(qubits).
                const minQ = Math.min(...op.qubits);
                const maxQ = Math.max(...op.qubits);
                const yTop = cy(minQ) - ROW_H / 2 + 6;
                const yBot = cy(maxQ) + ROW_H / 2 - 6;
                const h = yBot - yTop;
                return (
                  <g>
                    <rect
                      x={x - GATE_W / 2}
                      y={yTop}
                      width={GATE_W}
                      height={h}
                      rx={6}
                      fill={fillFor(op)}
                      stroke="rgb(148 163 184)"
                      stroke-width="1"
                    />
                    <text
                      x={x}
                      y={(yTop + yBot) / 2 + 4}
                      text-anchor="middle"
                      font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
                      font-size="9"
                      font-weight="600"
                      fill="rgb(241 245 249)"
                    >{op.label}</text>
                  </g>
                );
              }
              case "measure": {
                const y = cy(op.qubit);
                return (
                  <g>
                    <rect
                      x={x - GATE_W / 2}
                      y={y - GATE_H / 2}
                      width={GATE_W}
                      height={GATE_H}
                      rx={4}
                      fill={fillFor(op)}
                      stroke="rgb(148 163 184)"
                      stroke-width="1"
                    />
                    <text
                      x={x}
                      y={y + 4}
                      text-anchor="middle"
                      font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
                      font-size="13"
                      font-weight="600"
                      fill="rgb(241 245 249)"
                    >M</text>
                  </g>
                );
              }
              case "swap":
                return null; // drawn above
            }
          }),
        )}
      </svg>
    </div>

    <!-- Block legend — short captions explaining each section -->
    <ul class="mt-3 grid gap-1 text-xs text-ink-subtle sm:grid-cols-2">
      {circuit.blocks.map((b) => (
        <li>
          <strong class="text-ink">{b.label}:</strong> {b.caption}
        </li>
      ))}
    </ul>

    <!-- Qiskit CTA — prominent, no remix-in-sandbox link (D-15) -->
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm text-ink-subtle">
        You built the engine here; now run the real thing in Qiskit.
      </p>
      <button
        type="button"
        data-action="copy-shor-qiskit"
        data-qiskit={qiskitText}
        class="rounded-md border border-positive/40 bg-positive/10 px-3 py-2 text-sm font-semibold text-positive hover:bg-positive/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-positive"
        aria-label="Copy Shor N=15 Qiskit code"
      >Copy Shor N=15 Qiskit ↗</button>
    </div>
  </div>
  {caption && (
    <figcaption class="mt-2 text-sm text-ink-subtle">{caption}</figcaption>
  )}
</figure>

<script>
  // LargeCircuitView click hydrator — distinct action name from
  // CircuitView's "copy-qiskit" so the two never clobber each other
  // if they share a page (current /shor uses LargeCircuitView only).
  document.addEventListener("click", async (ev) => {
    const target = ev.target;
    if (!(target instanceof HTMLElement)) return;
    if (target.dataset.action !== "copy-shor-qiskit") return;
    const snippet = target.dataset.qiskit ?? "";
    const original = target.textContent;
    const flash = (msg: string) => {
      target.textContent = msg;
      window.setTimeout(() => { target.textContent = original; }, 1500);
    };
    try {
      await navigator.clipboard.writeText(snippet);
      flash("Copied!");
    } catch {
      flash("Copy failed");
    }
  });
</script>
