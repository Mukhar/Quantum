---
/**
 * BlochSphere — marquee single-qubit visualization.
 *
 * Renders one of two backends:
 *  - Sphere3D: Three.js scene with a draggable arrow. Lazy-loaded.
 *  - Polar2D: SVG fallback for narrow viewports / no WebGL / SSR.
 *
 * Backend selection happens client-side on mount. The server emits a
 * 2D-friendly DOM so the page is visible during JS load.
 */

interface Props {
  storeKey: string;
  /** Must always be 1 for this widget. Prop kept for symmetry with other widgets. */
  qubits?: 1;
  caption?: string;
  /** Force a specific backend (mostly for testing). */
  backend?: "auto" | "3d" | "2d";
}

const { storeKey, caption, backend = "auto" } = Astro.props as Props;
---

<figure
  class="my-6 rounded-lg border border-slate-800 bg-slate-900/40 p-5"
  data-widget="bloch-sphere"
  data-store-key={storeKey}
  data-qubits="1"
  data-backend={backend}
>
  {caption && <figcaption class="mb-3 text-sm text-slate-400">{caption}</figcaption>}
  <div
    data-role="mount"
    class="relative mx-auto aspect-square w-full max-w-sm select-none touch-none"
    role="application"
    aria-label="Bloch sphere — drag the arrow to set the qubit state"
  >
    <!-- SSR fallback: a tiny static SVG so layout doesn't jump while JS loads. -->
    <svg viewBox="0 0 200 200" class="w-full h-full text-slate-400" aria-hidden="true">
      <circle cx="100" cy="100" r="80" fill="none" stroke="currentColor" stroke-opacity="0.25" />
      <line x1="100" y1="20" x2="100" y2="180" stroke="currentColor" stroke-opacity="0.2" />
      <line x1="20" y1="100" x2="180" y2="100" stroke="currentColor" stroke-opacity="0.2" />
    </svg>
  </div>
  <p class="mt-3 text-xs text-slate-500" data-role="hint">
    Try dragging the arrow tip. Apply a gate above and watch the arrow rotate.
  </p>
</figure>

<script>
  import { ensureStore } from "../../lib/quantum/store";
  import { mountPolar2D } from "./Polar2D.client";

  const hasWebGL = (() => {
    try {
      const c = document.createElement("canvas");
      return !!(window.WebGLRenderingContext && (c.getContext("webgl") || c.getContext("experimental-webgl")));
    } catch { return false; }
  })();

  async function mount(el: HTMLElement) {
    const storeKey = el.dataset.storeKey!;
    const store = ensureStore(storeKey, { qubits: 1 });
    const mountEl = el.querySelector<HTMLElement>('[data-role="mount"]')!;

    const requested = el.dataset.backend ?? "auto";
    const wantsNarrow = window.innerWidth < 640;
    const use3D =
      requested === "3d" ||
      (requested === "auto" && hasWebGL && !wantsNarrow);

    if (use3D) {
      try {
        const { mountSphere3D } = await import("./Sphere3D.client");
        return mountSphere3D(mountEl, store);
      } catch (err) {
        console.warn("[BlochSphere] 3D backend failed, falling back to 2D", err);
        return mountPolar2D(mountEl, store);
      }
    }
    return mountPolar2D(mountEl, store);
  }

  document
    .querySelectorAll<HTMLElement>('[data-widget="bloch-sphere"]')
    .forEach(mount);
</script>
